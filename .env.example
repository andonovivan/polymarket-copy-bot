# ── Polymarket API credentials ──
# Generate these at https://polymarket.com (profile → API keys)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Wallet ──
# The private key of the wallet that will place copy-trades.
# NEVER commit this. Fund this wallet with USDC + a small amount of MATIC on Polygon.
PRIVATE_KEY=

# ── Wallets to copy (comma-separated) ──
# Find profitable traders on Polymarket leaderboards or via on-chain analytics.
TRACKED_WALLETS=0xabc...,0xdef...

# ── Mode ──
DRY_RUN=true                    # Set to false to place real orders

# ── Trading parameters ──
FIXED_AMOUNT_USDC=2            # Fixed $2 USDC per copied trade
MAX_POSITION_USDC=100           # Max USDC per market
PRICE_TOLERANCE=0.03            # Skip if price moved >3% from original
COPY_SELLS=true                 # Also copy exit / sell trades

# ── Bot behaviour ──
POLL_INTERVAL_SECONDS=30        # How often to check for new trades
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR

# ── Dashboard ──
DASHBOARD_PORT=8080             # Web dashboard at http://localhost:8080

# ── Advanced (usually leave defaults) ──
CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137
